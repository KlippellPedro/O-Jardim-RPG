# Modelo de configuracao da plataforma. Copie para .env e preencha.
# O .env real nunca vai para o Git nem para o ZIP de deploy: na Discloud os
# valores sao definidos pelo painel de variaveis do app.

# development liga a documentacao em /api/docs e desliga o cache de estaticos.
APP_ENV=development

# Obrigatorio. Local (docker-compose): postgresql://jardim:jardim@127.0.0.1:5433/jardim
# Producao: o hostname interno da VLAN do app de banco na Discloud.
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Segredo compartilhado apenas com os bots, para as rotas /api/v1/interno/*.
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(48))"
SERVICE_API_KEY=

# Conta criador: cargo unico, com acesso de admin e de mestre. O painel nunca
# concede nem remove esse cargo. CREATOR_USER_ID tem prioridade sobre o e-mail;
# prefira migrar para ele depois que a conta existir.
CREATOR_EMAIL=
CREATOR_USER_ID=

# Quem pode criar conta:
#   aberto  - qualquer pessoa (padrao fora de producao)
#   convite - exige um codigo de convite de campanha (padrao em producao)
#   fechado - ninguem se cadastra sozinho
# A conta de CREATOR_EMAIL sempre pode se cadastrar, senao o primeiro acesso
# ficaria travado antes de existir campanha para convidar alguem.
CADASTRO=aberto

# Cookies e sessao.
SESSION_COOKIE_NAME=oj_session
CSRF_COOKIE_NAME=oj_csrf
SESSION_DAYS=7
# Em producao deve ser true (exige HTTPS). Local fica false por causa do http://.
COOKIE_SECURE=false

# Listas separadas por virgula. Vazio libera apenas mesma origem.
# Producao: https://jardim-rpg.discloud.app
ALLOWED_ORIGINS=
# Producao: jardim-rpg.discloud.app,jardimapi
TRUSTED_HOSTS=

# Segundos de espera pelo banco no boot, antes de desistir.
DATABASE_STARTUP_TIMEOUT=15
