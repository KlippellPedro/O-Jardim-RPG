# Configure os valores reais no painel da Discloud. Nunca versione o .env real.
DISCORD_TOKEN=

# Use a string de conexao fornecida pelo template PostgreSQL da Discloud.
# Com VLAN, o host tem que ser EXATAMENTE o que aparece em "Conexao privada"
# na pagina do banco na Discloud (bancos de template ganham um hostname
# auto-gerado, tipo "klippell1422" — nao eh um nome bonito escolhido a mao,
# entao confira o valor real la, nao adivinhe).
DATABASE_URL=postgresql://USUARIO:SENHA@HOST_REAL_DO_PAINEL:5432/BANCO

# Opcional: sincroniza slash commands imediatamente neste servidor de testes.
GUILD_ID=

# Tempo maximo para validar o banco durante a inicializacao (5 a 60 segundos).
DATABASE_STARTUP_TIMEOUT=12

# Integracao privada com a plataforma web (mesma chave nos dois apps).
PLATFORM_API_URL=http://jardimapi:8080/api/v1
SERVICE_API_KEY=
