# Configure os valores reais no painel da Discloud (ou em .env local pra
# rodar na sua máquina). Nunca versione o .env real.
DISCORD_TOKEN=

# Opcional: sincroniza slash commands imediatamente neste servidor de testes.
GUILD_ID=

# Opcional — mesmo PostgreSQL central do Banqueiro/Jornalista. Sem isso, o
# Barista sobe normalmente e dados/música funcionam; só /playlist e /menu
# ficam indisponíveis. Com VLAN, o host tem que ser EXATAMENTE o que
# aparece em "Conexão privada" na página do banco na Discloud (bancos de
# template ganham um hostname auto-gerado tipo "klippell1422" — confira o
# valor real lá, não adivinhe).
DATABASE_URL=postgresql://USUARIO:SENHA@HOST_REAL_DO_PAINEL:5432/BANCO

# Tempo máximo (segundos) pra validar o banco durante a inicialização.
DATABASE_STARTUP_TIMEOUT=12
